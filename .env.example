PORT=3000

# URL publique du site, utilisée dans les emails (lien vers l'espace bénévole)
SITE_URL=http://localhost:3000

# Compte Gmail utilisé pour ENVOYER les emails (candidatures bénévoles, etc.)
# EMAIL_USER = l'adresse Gmail qui envoie
# EMAIL_PASS = un "mot de passe d'application" Gmail (PAS le mot de passe du compte)
#   -> https://myaccount.google.com/apppasswords (nécessite la validation en 2 étapes activée)
EMAIL_USER=
EMAIL_PASS=

# Adresse qui RECOIT les candidatures (par défaut : ecoute.anonyme26@gmail.com)
CONTACT_EMAIL=ecoute.anonyme26@gmail.com
