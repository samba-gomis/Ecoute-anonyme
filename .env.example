PORT=3000

# Connexion à la base Postgres (obligatoire).
# En local : URL d'une base Postgres locale, ex. postgres://user:pass@localhost:5432/ecoute_anonyme
# Sur Render : laissez Render la renseigner automatiquement via render.yaml
# (fromDatabase), ou collez l'"Internal Database URL" du service Postgres.
DATABASE_URL=

# URL publique du site, utilisée dans les emails (lien vers l'espace bénévole)
SITE_URL=http://localhost:3000

# Envoi d'emails (candidatures bénévoles, etc.) via l'API HTTP de Brevo —
# le SMTP sortant est bloqué sur Render, donc pas de Gmail SMTP ici.
# BREVO_API_KEY = clé API v3 -> https://app.brevo.com/settings/keys/api
# BREVO_SENDER_EMAIL = adresse expéditrice, doit être vérifiée dans Brevo
#   -> https://app.brevo.com/senders/list
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# Adresse qui RECOIT les candidatures (par défaut : ecoute.anonyme26@gmail.com)
CONTACT_EMAIL=ecoute.anonyme26@gmail.com
